# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Onyx AI & Edge Worker Config
# Use one canonical Worker URL for all frontend->Worker calls.
VITE_EDGE_WORKER_URL=http://localhost:8787
# Backward-compatible alias used by some existing service code.
VITE_ONYX_WORKER_URL=https://intake.your-worker.workers.dev
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# VITE_MOCK_LLM_ENABLED=false must be explicitly set to connect to the live Cloudflare Edge infrastructure.
# Setting it to true is only for offline UI development.
VITE_MOCK_LLM_ENABLED=false
